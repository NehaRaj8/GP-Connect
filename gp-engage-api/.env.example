# ============================================================
# GP Engage API — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- Supabase / PostgreSQL ---
# Found in: Supabase Dashboard → Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# --- JWT Authentication ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters-long
JWT_EXPIRES_IN=8h        # staff sessions
JWT_PATIENT_EXPIRES_IN=24h

# --- Redis (optional for dev — remove to disable caching) ---
# Supabase doesn't include Redis; use Upstash free tier: upstash.com
REDIS_URL=redis://default:[PASSWORD]@[HOST]:6379

# --- Server ---
PORT=3000
NODE_ENV=development     # development | production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- NHS Login (OAuth 2.0) ---
# Register at: https://digital.nhs.uk/services/nhs-login
NHS_LOGIN_CLIENT_ID=your-nhs-login-client-id
NHS_LOGIN_CLIENT_SECRET=your-nhs-login-client-secret
NHS_LOGIN_REDIRECT_URI=http://localhost:3000/auth/nhs-login/callback
NHS_LOGIN_SCOPE=openid profile nhs_number

# --- Notifications ---
# Twilio (SMS): twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+441234567890

# SMTP (email) — or use NHS Notify in production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@yourpractice.nhs.uk

# --- File Storage (Supabase Storage bucket) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
STORAGE_BUCKET=gp-engage-attachments

# --- Practice (single practice mode for MVP) ---
DEFAULT_PRACTICE_ID=your-practice-uuid-from-db
